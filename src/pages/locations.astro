---
import BaseLayout from '../layouts/BaseLayout.astro';

// 1. Описываем интерфейс (в единственном числе - Park)
interface Park {
  parkTitle: string;
  slug: string;
  image: string;
}

// 2. Объявляем массив СТРОГО внутри разделителей ---
const parks: Park[] = [
  { 
    parkTitle: "Парк культуры и отдыха", 
    slug: "park-kultury-otdyha", 
    image: "https://parkbugulma.ru/wp-content/uploads/tempForAstra/pkio2.jpg" 
  },
  { 
    parkTitle: "Сокольская гора", 
    slug: "sokolka", 
    image: "https://parkbugulma.ru/wp-content/uploads/tempForAstra/sokolka.jpg" 
  },
  { 
    parkTitle: "Центральная площадь", 
    slug: "centralnaya-ploshad", 
    image: "https://parkbugulma.ru/wp-content/uploads/tempForAstra/center2.jpg" 
  },
  { 
    parkTitle: "Набережная водоёма", 
    slug: "naberezhnaya", 
    image: "https://static.tildacdn.com/tild3139-3339-4639-b262-623234636566/SAN_0361.jpg" 
  },
    { 
    parkTitle: "Фонтаны возле ЦУМа", 
    slug: "naberezhnaya", 
    image: "https://parkbugulma.ru/wp-content/uploads/tempForAstra/fontanyCUM.jpg" 
  },
    { 
    parkTitle: "Площадь Дома техники", 
    slug: "dom-techniki", 
    image: "https://parkbugulma.ru/wp-content/uploads/tempForAstra/dt.jpg" 
  },
    { 
    parkTitle: "Детский парк", 
    slug: "detskiy-park", 
    image: "https://parkbugulma.ru/wp-content/uploads/photoalbum/parkphoto/parkphoto-(7).jpg" 
  },
    { 
    parkTitle: "Сквер Дворец молодежи", 
    slug: "skver-dvorec-molodezhy", 
    image: "https://parkbugulma.ru/wp-content/uploads/tempForAstra/dm.jpg" 
  },
    { 
    parkTitle: "Сквер им. П. Ненастина", 
    slug: "skver-petra-nenastina", 
    image: "https://parkbugulma.ru/wp-content/uploads/tempForAstra/Nenastina1.jpg" 
  },
      { 
    parkTitle: "Сквер им. С. Сайдашева", 
    slug: "skver-saliha-saydasheva", 
    image: "https://via.placeholder.com" 
  },
];
---

<BaseLayout title="Парки Бугульмы">
  <main class="bg-white">
    


       <!-- Hero Секция -->
    <section class="relative h-[40vh] min-h-[300px] flex items-center justify-center bg-zinc-900 overflow-hidden">
      <div class="absolute inset-0 z-0 opacity-50">
        <img src="https://parkbugulma.ru/wp-content/uploads/oparkehead.jpg" alt="Background" class="w-full h-full object-cover" />
      </div>
      
      <div class="relative z-10 text-center px-4">
        <!-- Тонкий заголовок: font-light и tracking-wide -->
        <h1 class="text-4xl md:text-5xl font-light text-white mb-3 tracking-wide drop-shadow-sm uppercase">
          Парки и скверы
        </h1>
        <p class="text-sm md:text-base text-zinc-300 max-w-xl mx-auto tracking-[0.2em] font-extralight">
          Откройте для себя лучшие места для отдыха в Бугульме
        </p>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 py-16">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
    {parks.map((item) => (
      <a 
        href={`/locations/${item.slug}`} 
        class="group relative block aspect-[4/5] overflow-hidden rounded-xl bg-zinc-200 transition-all duration-500"
      >
        <!-- Слой 1: Основная фотография (фон) -->
        <img 
          src={item.image} 
          alt={item.parkTitle} 
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-1000 group-hover:scale-110"
        />

        <!-- Слой 2: Светло-бирюзовая подложка -->
        <!-- По умолчанию видна (opacity-100), при наведении исчезает (group-hover:opacity-0) -->
        <div class="absolute inset-0 z-10 bg-[var(--color-teal-600)]/20 transition-opacity duration-500 group-hover:opacity-0"></div>

        <!-- Слой 3: Легкий градиент для текста (всегда виден снизу для читаемости) -->
        <div class="absolute inset-0 z-20 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-60"></div>
        
        <!-- Контент -->
        <div class="absolute inset-0 z-30 flex flex-col justify-end p-8">
<!-- Контент (слой z-30) -->
<div class="absolute inset-0 z-30 flex flex-col justify-end p-8">
  <h2 class="text-xl md:text-2xl font-light text-white tracking-wide transition-colors duration-500">
    {item.parkTitle}
  </h2>
  
  <!-- Тонкая белая линия (убрали смену цвета на бирюзовый) -->
  <div class="mt-4 w-12 h-px bg-white/50 transition-all duration-500 group-hover:w-full">
  </div>
</div>
</div>
      </a>
    ))}
  </div>
</section>

  </main>
</BaseLayout>
