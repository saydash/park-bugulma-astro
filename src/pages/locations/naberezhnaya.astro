---
import BaseLayout from '../../layouts/BaseLayout.astro';

const park = {
  title: "Набережная водоёма",
  subtitle: "Живописное сочетание культурного наследия и современного прибрежного отдыха",
  heroImage: "https://static.tildacdn.com/tild3139-3339-4639-b262-623234636566/SAN_0361.jpg", 
};

const zones = [
  "Музей Ярослава Гашека",
  "Скульптура Ярослава Гашека",
  "Детская площадка «Чудо-юдо рыба»",
  "Пешеходные и велодорожки",
  "Обновленный пешеходный мост",
  "Кормление уток у водоёма",
  "Скамейки для отдыха",
  "Прокат детских электромобилей"
];
---

<BaseLayout title={park.title}>
  <main class="bg-white">
    
    <!-- Hero Секция (85vh) -->
    <section class="relative h-[85vh] min-h-[600px] flex items-end bg-zinc-900 overflow-hidden">
      <div class="absolute inset-0 z-0">
        <img 
          src={park.heroImage} 
          alt={park.title} 
          class="w-full h-full object-cover opacity-60"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
      </div>
      
      <div class="relative z-10 max-w-7xl mx-auto px-6 pb-24 w-full">
        <p class="text-teal-500 uppercase tracking-[0.4em] text-xs md:text-sm font-medium mb-6">
          Культурный ландшафт • Набережная
        </p>
        <h1 class="text-5xl md:text-8xl font-light text-white tracking-tight leading-[0.9] max-w-4xl">
          {park.title}
        </h1>
      </div>
    </section>

    <!-- Секция с контентом -->
    <section class="max-w-4xl mx-auto px-6 py-32 bg-white">
      
      <!-- Блок 1: Вводная часть -->
      <div class="block">
        <h2 class="text-2xl md:text-3xl font-light text-zinc-900 leading-snug mb-8">
          {park.subtitle}
        </h2>
        <p class="text-xl font-light text-zinc-500 leading-relaxed">
          Набережная центрального водоёма — это сердце Бугульмы, где история города встречается с его будущим. Пространство объединяет в себе тишину водной глади, пространство для прогулок и уникальные арт-объекты, рассказывающие о богатом прошлом нашего края..
        </p>
      </div>

      <!-- Распорка (96px) -->
      <div class="h-24 w-full"></div>

      <!-- Блок 2: Основной текст -->
      <div class="block">
        <div class="text-zinc-600 font-light leading-loose text-lg space-y-10">
          <p>
            Знаковым культурным центром набережной является единственный в России <strong class="font-medium text-zinc-800">мемориальный музей Ярослава Гашека</strong>. Расположенный здесь же памятник выдающемуся чешскому писателю-сатирику напоминает о времени его службы комендантом Бугульмы. Эти исторические точки притяжения задают особый интеллигентный тон всему пространству набережной.
          </p>
          <p>
            После масштабной реконструкции береговая зона превратилась в современный променад. Обновленный пешеходный мост через водоём стал не только важной артерией, но и лучшей точкой для обзора панорамы водоёма. Для любителей активного образа жизни вдоль всей береговой линии проложены велосипедные и пешеходные дорожки с качественным покрытием.
          </p>
          <p>
            Маленьких посетителей ждет тематическая игровая зона <strong class="font-medium text-zinc-800">«Чудо-юдо рыба»</strong>. Пока дети играют на площадке или катаются на электромобилях, взрослые могут насладиться спокойствием на скамейках для отдыха или покормить уток, которые давно стали постоянными обитателями водоёма и символом уюта этой территории.
        </div>
      </div>

      <!-- Распорка (96px) -->
      <div class="h-24 w-full"></div>

      <!-- Блок 3: Инфраструктура (Зоны) -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-y-8 gap-x-12">
        {zones.map((zone) => (
          <div class="flex items-center space-x-5 group">
            <span class="block flex-shrink-0 w-2.5 h-2.5 bg-teal-600 rotate-45 transition-transform duration-300 group-hover:rotate-0"></span>
            <span class="text-zinc-800 font-light tracking-wide text-lg leading-tight">
              {zone}
            </span>
          </div>
        ))}
      </div>

      <!-- Распорка (96px) -->
      <div class="h-24 w-full"></div>

      <!-- Блок 4: Футер -->
      <div class="pt-12 border-t border-zinc-200 mb-20">
        <a 
          href="/locations" 
          class="inline-flex items-center space-x-4 text-teal-600 font-light tracking-widest uppercase text-sm transition-all duration-300 hover:text-zinc-900 group"
        >
          <span class="text-2xl transform transition-transform group-hover:-translate-x-2">←</span> 
          <span>Вернуться к списку пространств</span>
        </a>
      </div>

    </section>
  </main>
</BaseLayout>
