---
import BaseLayout from '../../layouts/BaseLayout.astro';

const park = {
  title: "Сокольская гора",
  subtitle: "Главная смотровая площадка и сердце активного отдыха города",
  heroImage: "https://parkbugulma.ru/wp-content/uploads/tempForAstra/sokolka.jpg", 
};

const zones = [
  "Смотровая площадка с качелями",
  "Зона семейного BBQ",
  "Детская игровая площадка",
  "Площадка для Workout"
];
---

<BaseLayout title={park.title}>
  <main class="bg-white">
    
    <!-- Hero Секция -->
    <section class="relative h-[85vh] min-h-[600px] flex items-end bg-zinc-900 overflow-hidden">
      <div class="absolute inset-0 z-0">
        <img 
          src={park.heroImage} 
          alt={park.title} 
          class="w-full h-full object-cover opacity-60"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
      </div>
      
      <div class="relative z-10 max-w-7xl mx-auto px-6 pb-24 w-full">
        <p class="text-teal-500 uppercase tracking-[0.4em] text-xs md:text-sm font-medium mb-6">
          Природный ландшафт • Соколка
        </p>
        <h1 class="text-5xl md:text-8xl font-light text-white tracking-tight leading-[0.9] max-w-4xl">
          {park.title}
        </h1>
      </div>
    </section>

       <!-- Основная секция контента -->
<section class="max-w-4xl mx-auto px-6 py-32 bg-white">
  
  <!-- Блок 1: Заголовок и подзаголовок -->
  <div class="block">
    <h2 class="text-2xl md:text-3xl font-light text-zinc-900 leading-snug mb-6">
      {park.subtitle}
    </h2>
    <p class="text-xl font-light text-zinc-500 leading-relaxed">
      Сокольская гора — это уникальное сочетание панорамных видов и современной инфраструктуры...
    </p>
  </div>

  <!-- Распорка 1 (96px) -->
  <div class="h-24 w-full"></div>

  <!-- Блок 2: Основной текст -->
  <div class="block">
    <div class="text-zinc-600 font-light leading-loose text-lg space-y-8">
        <p>
          Главной изюминкой пространства стала обновленная смотровая площадка. Установленные здесь панорамные качели позволяют буквально парить над городом, наслаждаясь тишиной и бескрайними горизонтами. Это идеальное место для закатных прогулок и памятных фотографий.
        </p>
        
        <p>
          Для любителей гастрономического отдыха на природе предусмотрена выделенная BBQ-зона. Она спроектирована так, чтобы компании могли отдыхать с комфортом, не мешая друг другу и сохраняя чистоту окружающего ландшафта.
        </p>

        <p>
          Активная часть парка представлена современным Workout-комплексом и безопасной детской площадкой, материалы которых гармонично вписаны в природную среду. Соколка сегодня — это баланс между дикой природой и продуманным городским сервисом.
        </p>
    </div>
  </div>

  <!-- Распорка 2 (96px) -->
  <div class="h-24 w-full"></div>

  <!-- Блок 3: Инфраструктура (Зоны) -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-y-10 gap-x-12">
    {zones.map((zone) => (
      <div class="flex items-center space-x-4">
        <!-- Маркер: используем inline-block и принудительный размер -->
        <span class="block flex-shrink-0 w-3 h-3 bg-teal-600 rotate-45"></span>
        <span class="text-zinc-800 font-light tracking-wide text-lg">
          {zone}
        </span>
      </div>
    ))}
  </div>

  <!-- Распорка 3 (96px) -->
  <div class="h-24 w-full"></div>

  <!-- Блок 4: Футер -->
  <div class="pt-12 border-t border-zinc-200">
    <a 
      href="/locations" 
      class="inline-flex items-center space-x-3 text-teal-600 font-light tracking-widest uppercase text-sm"
    >
      <span class="text-xl">←</span> 
      <span>К списку пространств</span>
    </a>
  </div>

</section>

  </main>
</BaseLayout>
