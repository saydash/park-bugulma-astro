---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Данные конкретного парка (в будущем придут из WordPress по slug)
const park = {
  title: "Центральная площадь",
  subtitle: "Центральная площадь города",
  heroImage: "https://parkbugulma.ru/wp-content/uploads/tempForAstra/center2.jpg", // Замените на вашу ссылку
};
---

<BaseLayout title={park.title}>
  <main class="bg-white">
    
        <!-- Hero Секция (Увеличенная высота) -->
    <section class="relative h-[85vh] min-h-[600px] flex items-end bg-zinc-900 overflow-hidden">
      <!-- Фоновое изображение -->
      <div class="absolute inset-0 z-0">
        <img 
          src={park.heroImage} 
          alt={park.title} 
          class="w-full h-full object-cover opacity-60 transition-transform duration-[10000ms] hover:scale-110"
        />
        <!-- Более глубокий градиент для высокого Hero -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
      </div>
      
      <!-- Заголовок в Hero (снизу слева) -->
      <div class="relative z-10 max-w-7xl mx-auto px-6 pb-24 w-full">
        <div class="overflow-hidden">
           <p class="text-teal-500 uppercase tracking-[0.4em] text-xs md:text-sm font-medium mb-6 animate-fade-in-up">
            Общественное пространство
          </p>
        </div>
        <h1 class="text-5xl md:text-8xl font-light text-white tracking-tight leading-[0.9] max-w-4xl">
          {park.title}
        </h1>
        
      </div>
    </section>

    <!-- Секция с контентом -->
    <section class="max-w-4xl mx-auto px-6 py-32">
      <div class="prose prose-zinc lg:prose-xl">


        <!-- Основной текст -->
        <div class="space-y-8 text-zinc-600 font-light leading-loose text-lg">
          <p>
            Центральная площадь Бугульмы — это сердце города, где жизнь кипит в любое время года. Именно здесь разворачиваются главные городские события: гремят масштабные концерты в День города и День нефтяника, проходят яркие фестивали и народные гулянья. В теплые дни площадь наполняется ароматами сахарной ваты и мороженого, а прохладу дарят два живописных фонтана, один из которых радует жителей и гостей города светомузыкальными представлениями.
          </p>
          
          <p>
            К площади примыкает уютный зеленый сквер, где в тени высоких деревьев можно отдохнуть от суеты. Это идеальное место для семейного досуга: здесь расположена современная детская площадка с удобными скамейками для родителей и оборудованный скейт-парк для любителей экстрима. С приходом зимы пространство преображается — на площади заливают каток и возводят снежные горки, превращая её в центр зимних забав и праздничного настроения.
          </p>

         
        </div>

        <!-- Кнопка возврата (опционально) -->
        <div class="mt-24 pt-12 border-t border-zinc-100 mb-20">
          <a 
            href="/locations" 
            class="inline-flex items-center gap-3 text-teal-600 font-light tracking-widest uppercase text-sm transition-all duration-300 hover:text-zinc-900 group"
          >
            <span class="text-xl transform transition-transform group-hover:-translate-x-2">←</span> 
            Вернуться к списку пространств
          </a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
